### 1. テストデータ生成 
```python
def generate_test_sensor_data(sensor_type: str, custom_values: dict = None) -> bytes:
    """テスト用センサーデータの生成"""
    base_templates = {
        'vibration': "ERXDATA 1115 0000 0464 F000 4D 7A 03030900...",
        'temperature_humidity': "ERXDATA 0002 0000 62BE F000 18 20 030301FF...",
        'current_pulse': "ERXDATA B07C 0000 3D3C F000 4D 3A 030310FF..."
    }
    
    template = base_templates.get(sensor_type, base_templates['vibration'])
    
    # カスタム値でテンプレートを更新
    if custom_values:
        # テンプレートにカスタム値を適用
        pass
    
    return template.encode('utf-8')
```

### 2. アサーションヘルパー 
```python
def assert_sensor_data_valid(sensor_data: dict, sensor_type: str):
    """センサーデータの妥当性を包括的にチェック"""
    assert sensor_data is not None
    assert 'values' in sensor_data
    assert 'RSSI' in sensor_data
    assert 'addr' in sensor_data
    
    values = sensor_data['values']
    
    # センサータイプ固有の検証
    if sensor_type == 'vibration':
        required_fields = ['vibration_x', 'vibration_y', 'vibration_z']
        for field in required_fields:
            assert field in values
            assert isinstance(values[field], (int, float))
    
    elif sensor_type == 'temperature_humidity':
        assert 'temperature' in values
        assert 'humidity' in values
        assert -40 <= values['temperature'] <= 85  # 温度範囲チェック
        assert 0 <= values['humidity'] <= 100     # 湿度範囲チェック
```

