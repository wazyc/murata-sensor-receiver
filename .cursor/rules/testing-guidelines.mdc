## エラーハンドリングテスト 

### 1. 例外テスト 
```python
class TestSensorExceptions:
    def test_invalid_checksum_raises_exception(self):
        """不正なチェックサムで例外が発生することを確認"""
        invalid_data = b"ERXDATA...invalid_checksum..."
        
        with pytest.raises(FailedCheckSum) as exc_info:
            MurataSensorBase(invalid_data, ('127.0.0.1', 55039))
        
        assert "Failed to validate message checksum" in str(exc_info.value)
    
    def test_payload_checksum_error(self):
        """ペイロードチェックサムエラーのテスト"""
        invalid_payload_data = b"ERXDATA...invalid_payload..."
        
        with pytest.raises(FailedCheckSumPayload):
            MurataSensorBase(invalid_payload_data, ('127.0.0.1', 55039))
```

### 2. グレースフルな劣化テスト 
```python
def test_receiver_continues_after_sensor_error():
    """センサーエラー発生後もレシーバーが継続することを確認"""
    receiver = MurataReceiver(55039)
    
    # 不正なデータを送信
    invalid_data = b"INVALID_DATA"
    result = receiver.make_sensor(invalid_data, ('127.0.0.1', 55039))
    
    # Noneが返されることを確認（システムは継続）
    assert result is None
    
    # 正常なデータも処理できることを確認
    valid_data = TEMPERATURE_HUMIDITY_VALID[0][0]
    result = receiver.make_sensor(valid_data, ('127.0.0.1', 55039))
    assert result is not None
```

## パフォーマンステスト 

### 1. 負荷テスト 
```python
import time
import threading

def test_high_frequency_data_processing():
    """高頻度データ処理のパフォーマンステスト"""
    receiver = MurataReceiver(55039)
    
    # 大量のデータを短時間で送信
    start_time = time.time()
    
    for i in range(1000):
        test_data = generate_test_sensor_data(i)
        receiver.make_sensor(test_data, ('127.0.0.1', 55039 + i))
    
    end_time = time.time()
    processing_time = end_time - start_time
    
    # パフォーマンス要件: 1秒あたり100パケット以上処理
    assert processing_time < 10.0  # 1000パケットを10秒以内
    assert len(receiver.sensors) == 1000
```

### 2. メモリ使用量テスト 
```python
import psutil
import gc

def test_memory_usage_with_large_history():
    """大量の履歴データでのメモリ使用量テスト"""
    process = psutil.Process()
    initial_memory = process.memory_info().rss
    
    receiver = MurataReceiver(55039)
    
    # 大量のデータを蓄積
    for i in range(10000):
        test_data = generate_test_sensor_data(i)
        receiver.make_sensor(test_data, ('127.0.0.1', 55039))
    
    gc.collect()  # ガベージコレクション実行
    final_memory = process.memory_info().rss
    memory_increase = (final_memory - initial_memory) / 1024 / 1024  # MB
    
    # メモリ使用量が許容範囲内であることを確認
    assert memory_increase < 100  # 100MB以下
```

