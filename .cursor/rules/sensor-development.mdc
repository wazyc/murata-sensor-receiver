def test_new_sensor_type():
    """新しいセンサータイプのテスト"""
    test_data = b"ERXDATA..."  # テストデータ
    sensor = NewSensorTypeSensor(test_data, ('127.0.0.1', 55039))
    
    assert sensor.values is not None
    assert 'sensor_value' in sensor.values
    assert sensor.info['RSSI'] is not None
