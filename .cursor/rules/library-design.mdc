    使用例:
        def data_handler(sensor_data, addr):
            print(f"受信データ: {sensor_data}")

        receiver = MurataReceiver(port=55039, data_callback=data_handler)
        receiver.recv()
    """

    def __init__(self, port: int, buffer_size: int = 1024,
                 data_callback: Optional[Callable] = None,
                 error_callback: Optional[Callable] = None,
                 logger: Optional[logging.Logger] = None):
        """
        MurataReceiverを初期化します。

        Args:
            port: 受信ポート番号（必須）
            buffer_size: 受信バッファサイズ（オプション、デフォルト: 1024）
